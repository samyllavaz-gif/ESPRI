<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ESPRI-Implante</title>
<style>
  /* ── Tokens ────────────────────────────────── */
  :root {
    --teal:        #1A7A7A;
    --teal-mid:    #2A9D8F;
    --teal-light:  #E6F4F4;
    --teal-border: #B2DEDE;
    --slate:       #1E2D3D;
    --gray-1:      #F2F5F7;
    --gray-2:      #E4E9ED;
    --gray-3:      #B0BAC3;
    --gray-4:      #6B7A88;
    --text:        #1E2D3D;
    --white:       #FFFFFF;
    --orange:      #E07B39;
    --orange-bg:   #FDF3EC;
    --red:         #C0392B;
    --red-bg:      #FDECEA;
    --green:       #1E7E5C;
    --green-bg:    #EAF7F1;
    --yellow:      #B07A00;
    --yellow-bg:   #FFF8E1;

    --radius-sm:   6px;
    --radius-md:   12px;
    --radius-lg:   18px;
    --shadow:      0 2px 12px rgba(30,45,61,.08);
    --shadow-md:   0 4px 24px rgba(30,45,61,.12);

    --font-body: 'Segoe UI', system-ui, -apple-system, sans-serif;
  }

  /* ── Reset ─────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 16px; }
  body {
    font-family: var(--font-body);
    background: var(--gray-1);
    color: var(--text);
    line-height: 1.55;
    min-height: 100vh;
  }

  /* ── Layout ────────────────────────────────── */
  .page-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 16px 64px;
  }

  /* ── Header ────────────────────────────────── */
  .site-header {
    background: var(--teal);
    color: var(--white);
    padding: 28px 24px 24px;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    margin-bottom: 28px;
    box-shadow: var(--shadow-md);
    position: relative;
    overflow: hidden;
  }
  .site-header::after {
    content: '';
    position: absolute;
    right: -40px; top: -40px;
    width: 200px; height: 200px;
    border-radius: 50%;
    background: rgba(255,255,255,.06);
    pointer-events: none;
  }
  .header-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    opacity: .7;
    margin-bottom: 4px;
  }
  .header-title {
    font-size: clamp(22px, 5vw, 30px);
    font-weight: 800;
    letter-spacing: -.01em;
    line-height: 1.15;
  }
  .header-sub {
    font-size: 13px;
    opacity: .82;
    margin-top: 4px;
    font-weight: 500;
  }
  .header-intro {
    font-size: 13px;
    opacity: .75;
    margin-top: 14px;
    max-width: 580px;
    line-height: 1.5;
  }

  /* ── Score badge (sticky) ───────────────────── */
  .score-bar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--white);
    border-bottom: 2px solid var(--teal-border);
    padding: 10px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    box-shadow: 0 2px 8px rgba(30,45,61,.1);
  }
  .score-bar-label { font-size: 12px; font-weight: 600; color: var(--gray-4); text-transform: uppercase; letter-spacing: .08em; }
  .score-bar-right { display: flex; align-items: center; gap: 10px; }
  .score-number {
    font-size: 26px;
    font-weight: 800;
    color: var(--teal);
    line-height: 1;
    min-width: 40px;
    text-align: right;
    transition: color .2s;
  }
  .score-pts { font-size: 12px; color: var(--gray-4); margin-top: 2px; }
  .badge {
    padding: 5px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .03em;
    white-space: nowrap;
    transition: all .2s;
  }
  .badge-geral    { background: var(--gray-2); color: var(--gray-4); }
  .badge-baixa    { background: #EEF6FF; color: #2563EB; }
  .badge-media    { background: var(--yellow-bg); color: var(--yellow); }
  .badge-alta     { background: var(--red-bg); color: var(--red); }

  /* ── Cards ──────────────────────────────────── */
  .card {
    background: var(--white);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow);
    margin-bottom: 16px;
    overflow: hidden;
  }
  .card-header {
    padding: 14px 20px 12px;
    border-bottom: 1px solid var(--gray-2);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .card-header-icon {
    width: 28px; height: 28px;
    border-radius: 8px;
    background: var(--teal-light);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
  }
  .card-header h2 {
    font-size: 14px;
    font-weight: 700;
    color: var(--teal);
    letter-spacing: .01em;
  }
  .card-body { padding: 18px 20px; }

  /* ── Form fields ────────────────────────────── */
  .fields-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px;
    margin-bottom: 14px;
  }
  .field-group { display: flex; flex-direction: column; gap: 5px; }
  .field-group label { font-size: 11px; font-weight: 700; color: var(--gray-4); text-transform: uppercase; letter-spacing: .07em; }
  .field-group input,
  .field-group select,
  .field-group textarea {
    border: 1.5px solid var(--gray-2);
    border-radius: var(--radius-sm);
    padding: 8px 10px;
    font-size: 14px;
    font-family: inherit;
    color: var(--text);
    background: var(--white);
    transition: border-color .15s;
    outline: none;
  }
  .field-group input:focus,
  .field-group select:focus,
  .field-group textarea:focus { border-color: var(--teal-mid); }
  .field-group textarea { resize: vertical; min-height: 72px; width: 100%; }
  .field-full { grid-column: 1 / -1; }

  /* ── Section headers inside cards ──────────── */
  .subsection-label {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--teal);
    margin: 20px 0 10px;
    padding-bottom: 6px;
    border-bottom: 2px solid var(--teal-border);
  }
  .subsection-label:first-child { margin-top: 0; }

  .pts-legend {
    display: flex;
    gap: 16px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .pts-chip {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: var(--gray-4);
  }
  .pts-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
  }
  .pts-dot-3 { background: var(--red); }
  .pts-dot-2 { background: var(--orange); }
  .pts-dot-1 { background: #2563EB; }

  /* ── Checkboxes ─────────────────────────────── */
  .check-list { display: flex; flex-direction: column; gap: 4px; }
  .check-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background .12s;
    border: 1.5px solid transparent;
    position: relative;
  }
  .check-item:hover { background: var(--gray-1); }
  .check-item.checked { background: var(--teal-light); border-color: var(--teal-border); }
  .check-item.checked-alert { background: var(--red-bg); border-color: #F5C6C2; }

  .check-item input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 20px; height: 20px;
    min-width: 20px;
    border: 2px solid var(--gray-3);
    border-radius: 5px;
    cursor: pointer;
    margin-top: 1px;
    transition: all .15s;
    background: var(--white);
    display: flex; align-items: center; justify-content: center;
    position: relative;
    flex-shrink: 0;
  }
  .check-item input[type="checkbox"]:checked {
    background: var(--teal);
    border-color: var(--teal);
  }
  .check-item input[type="checkbox"]:checked::after {
    content: '';
    position: absolute;
    left: 4px; top: 1px;
    width: 8px; height: 5px;
    border-left: 2px solid white;
    border-bottom: 2px solid white;
    transform: rotate(-45deg);
  }
  .check-item.checked-alert input[type="checkbox"]:checked {
    background: var(--red);
    border-color: var(--red);
  }

  .check-text { flex: 1; font-size: 14px; color: var(--text); line-height: 1.4; padding-top: 1px; }
  .check-pts {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .04em;
    padding: 2px 7px;
    border-radius: 20px;
    white-space: nowrap;
    margin-top: 2px;
    flex-shrink: 0;
  }
  .pts-3 { background: var(--red-bg); color: var(--red); }
  .pts-2 { background: var(--orange-bg); color: var(--orange); }
  .pts-1 { background: #EEF6FF; color: #2563EB; }
  .pts-alert { background: var(--red-bg); color: var(--red); font-size: 10px; }

  /* ── Alert box ──────────────────────────────── */
  .alert-box {
    display: none;
    background: var(--red-bg);
    border: 1.5px solid #F5C6C2;
    border-radius: var(--radius-sm);
    padding: 12px 16px;
    font-size: 13px;
    color: var(--red);
    font-weight: 600;
    margin-top: 12px;
    line-height: 1.45;
  }
  .alert-box::before { content: '⚠ '; }
  .alert-box.visible { display: block; }

  /* ── Result card ────────────────────────────── */
  .result-card {
    background: var(--slate);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 16px;
    box-shadow: var(--shadow-md);
  }
  .result-top {
    padding: 18px 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    border-bottom: 1px solid rgba(255,255,255,.08);
  }
  .result-score-wrap { text-align: center; }
  .result-score-num {
    font-size: 52px;
    font-weight: 900;
    color: var(--white);
    line-height: 1;
    letter-spacing: -.03em;
  }
  .result-score-label { font-size: 11px; color: rgba(255,255,255,.5); text-transform: uppercase; letter-spacing: .1em; margin-top: 3px; }
  .result-class-wrap { flex: 1; text-align: right; }
  .result-class-label { font-size: 11px; color: rgba(255,255,255,.4); text-transform: uppercase; letter-spacing: .1em; margin-bottom: 4px; }
  .result-class-name {
    font-size: clamp(17px, 4vw, 22px);
    font-weight: 800;
    color: var(--white);
    transition: color .2s;
  }

  .result-text-area { padding: 18px 22px; }
  .result-text-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(255,255,255,.45);
    margin-bottom: 10px;
  }
  .generated-text {
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: var(--radius-sm);
    padding: 13px 15px;
    font-size: 13.5px;
    color: rgba(255,255,255,.9);
    line-height: 1.55;
    min-height: 72px;
    font-family: var(--font-body);
    user-select: text;
  }
  .char-counter {
    text-align: right;
    font-size: 11px;
    color: rgba(255,255,255,.35);
    margin-top: 6px;
    font-variant-numeric: tabular-nums;
  }
  .char-counter.over { color: var(--red); }

  /* ── Buttons ────────────────────────────────── */
  .btn-row {
    display: flex;
    gap: 10px;
    padding: 0 22px 20px;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: all .15s;
    outline: none;
  }
  .btn-copy {
    background: var(--teal-mid);
    color: var(--white);
    flex: 1;
  }
  .btn-copy:hover { background: var(--teal); }
  .btn-copy.copied { background: var(--green); }
  .btn-clear {
    background: rgba(255,255,255,.08);
    color: rgba(255,255,255,.6);
    border: 1px solid rgba(255,255,255,.12);
  }
  .btn-clear:hover { background: rgba(255,255,255,.14); color: var(--white); }

  /* ── Aviso ──────────────────────────────────── */
  .aviso {
    font-size: 11.5px;
    color: var(--gray-4);
    background: var(--gray-2);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    margin-bottom: 16px;
    line-height: 1.5;
  }
  .aviso strong { color: var(--slate); }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 480px) {
    .score-bar { padding: 8px 14px; }
    .card-body { padding: 14px 14px; }
    .result-top { flex-direction: column; align-items: flex-start; gap: 8px; }
    .result-class-wrap { text-align: left; }
    .result-score-num { font-size: 42px; }
    .btn-row { padding: 0 14px 16px; }
    .fields-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
<body>

<header class="site-header">
  <div class="page-wrap" style="padding-bottom:0">
    <div class="header-eyebrow">Ferramenta de apoio — APS</div>
    <div class="header-title">ESPRI-Implante</div>
    <div class="header-sub">Escore de Priorização para Implante Subdérmico</div>
    <div class="header-intro">Ferramenta de apoio para classificação de prioridade na oferta do implante subdérmico de etonogestrel, conforme critérios de vulnerabilidade social, risco reprodutivo, risco clínico e dificuldade de adesão contraceptiva.</div>
  </div>
</header>

<!-- Score bar sticky -->
<div class="score-bar">
  <span class="score-bar-label">ESPRI Score</span>
  <div class="score-bar-right">
    <div>
      <div class="score-number" id="score-bar-num">0</div>
      <div class="score-pts">pontos</div>
    </div>
    <div class="badge badge-geral" id="score-bar-badge">Lista geral</div>
  </div>
</div>

<div class="page-wrap">

  <!-- Aviso -->
  <div class="aviso" style="margin-top:18px">
    <strong>Aviso:</strong> Esta ferramenta não substitui avaliação clínica, aconselhamento contraceptivo, exclusão de gestação e verificação de contraindicações.
  </div>

  <!-- ── DADOS CLÍNICOS ── -->
  <div class="card">
    <div class="card-header">
      <div class="card-header-icon">📋</div>
      <h2>Dados clínicos resumidos <span style="font-weight:400;color:var(--gray-3)">(opcionais)</span></h2>
    </div>
    <div class="card-body">
      <div class="fields-grid">
        <div class="field-group">
          <label for="f-idade">Idade</label>
          <input type="number" id="f-idade" min="10" max="60" placeholder="anos">
        </div>
        <div class="field-group">
          <label for="f-dum">DUM</label>
          <input type="text" id="f-dum" placeholder="DD/MM/AA">
        </div>
        <div class="field-group">
          <label for="f-g">Gestações</label>
          <input type="number" id="f-g" min="0" placeholder="G">
        </div>
        <div class="field-group">
          <label for="f-p">Partos</label>
          <input type="number" id="f-p" min="0" placeholder="P">
        </div>
        <div class="field-group">
          <label for="f-a">Abortos</label>
          <input type="number" id="f-a" min="0" placeholder="A">
        </div>
        <div class="field-group">
          <label for="f-metodo">Método atual</label>
          <select id="f-metodo">
            <option value="">—</option>
            <option>Nenhum</option>
            <option>Preservativo</option>
            <option>Anticoncepcional oral</option>
            <option>Injetável mensal</option>
            <option>Injetável trimestral</option>
            <option>DIU</option>
            <option>Outro</option>
          </select>
        </div>
        <div class="field-group field-full">
          <label for="f-resumo">Resumo / motivo da solicitação</label>
          <textarea id="f-resumo" placeholder="Ex: adolescente com vida sexual ativa, baixa adesão ao método oral, gestação prévia não planejada…"></textarea>
        </div>
      </div>
    </div>
  </div>

  <!-- ── CHECKLIST ESPRI ── -->
  <div class="card">
    <div class="card-header">
      <div class="card-header-icon">✓</div>
      <h2>Checklist ESPRI-Implante</h2>
    </div>
    <div class="card-body">
        <div class="pts-chip"><div class="pts-dot pts-dot-2"></div>2 pontos — risco moderado</div>
        <div class="pts-chip"><div class="pts-dot pts-dot-1"></div>1 ponto — prioridade adicional</div>
      </div>

      <!-- 3 pontos -->
      <div class="subsection-label">Vulnerabilidade social e risco reprodutivo</div>
      <div class="check-list" id="list-3">
        <label class="check-item" data-pts="3"><input type="checkbox"><span class="check-text">Adolescente de 14 a 17 anos com vida sexual ativa ou risco de gestação</span></label>
        <label class="check-item" data-pts="3"><input type="checkbox"><span class="check-text">Gestação prévia na adolescência ou puerpério adolescente</span></label>
        <label class="check-item" data-pts="3"><input type="checkbox"><span class="check-text">Situação de rua</span></label>
        <label class="check-item" data-pts="3"><input type="checkbox"><span class="check-text">Uso abusivo / dependência de álcool ou outras drogas</span></label>
        <label class="check-item" data-pts="3"><input type="checkbox"><span class="check-text">Profissional do sexo</span></label>
        <label class="check-item" data-pts="3"><input type="checkbox"><span class="check-text">Privação de liberdade ou egressa recente</span></label>
        <label class="check-item" data-pts="3"><input type="checkbox"><span class="check-text">Violência sexual, doméstica ou exploração sexual</span></label>
        <label class="check-item" data-pts="3"><input type="checkbox"><span class="check-text">Condição clínica em que gestação oferece alto risco</span></label>
        <label class="check-item" data-pts="3"><input type="checkbox"><span class="check-text">Uso de medicação potencialmente teratogênica</span></label>
      </div>

      <!-- 2 pontos -->
      <div class="subsection-label">Risco clínico e dificuldade de adesão</div>
      <div class="check-list" id="list-2">
        <label class="check-item" data-pts="2"><input type="checkbox"><span class="check-text">Pós-parto ou pós-abortamento recente com gestação não planejada</span></label>
        <label class="check-item" data-pts="2"><input type="checkbox"><span class="check-text">Baixa adesão comprovada a pílula ou injetável</span></label>
        <label class="check-item" data-pts="2"><input type="checkbox"><span class="check-text">Contraindicação ou intolerância a estrogênio</span></label>
        <label class="check-item" data-pts="2"><input type="checkbox"><span class="check-text">Dificuldade de acesso regular à unidade</span></label>
        <label class="check-item" data-pts="2"><input type="checkbox"><span class="check-text">Transtorno mental grave com dificuldade de adesão contraceptiva</span></label>
        <label class="check-item" data-pts="2"><input type="checkbox"><span class="check-text">Deficiência intelectual / cognitiva, com avaliação individualizada</span></label>
      </div>

      <!-- 1 ponto -->
      <div class="subsection-label">Critérios adicionais</div>
      <div class="check-list" id="list-1">
        <label class="check-item" data-pts="1"><input type="checkbox"><span class="check-text">Multiparidade com desejo de evitar nova gestação</span></label>
        <label class="check-item" data-pts="1"><input type="checkbox"><span class="check-text">Recusa ou contraindicação ao DIU</span></label>
        <label class="check-item" data-pts="1"><input type="checkbox"><span class="check-text">Gestação não planejada prévia</span></label>
        <label class="check-item" data-pts="1"><input type="checkbox"><span class="check-text">Jovem de 18 a 24 anos com dificuldade de adesão contraceptiva</span></label>
        <label class="check-item" data-pts="1"><input type="checkbox"><span class="check-text">Demanda espontânea por método de longa duração</span></label>
      </div>

    </div>
  </div>

  <!-- ── CONTRAINDICAÇÕES ── -->
  <div class="card">
    <div class="card-header">
      <div class="card-header-icon" style="background:var(--red-bg)">⚠</div>
      <h2 style="color:var(--red)">Atenção: avaliar antes de inserir</h2>
    </div>
    <div class="card-body">
      <div class="check-list" id="list-alert">
        <label class="check-item" data-alert="1"><input type="checkbox"><span class="check-text">Gestação confirmada ou suspeita</span></label>
        <label class="check-item" data-alert="1"><input type="checkbox"><span class="check-text">Sangramento uterino anormal sem investigação</span></label>
        <label class="check-item" data-alert="1"><input type="checkbox"><span class="check-text">Câncer de mama atual ou suspeito</span></label>
        <label class="check-item" data-alert="1"><input type="checkbox"><span class="check-text">Doença hepática grave ativa ou tumor hepático</span></label>
        <label class="check-item" data-alert="1"><input type="checkbox"><span class="check-text">Alergia conhecida ao método</span></label>
        <label class="check-item" data-alert="1"><input type="checkbox"><span class="check-text">Infecção ou lesão no local previsto de inserção</span></label>
      </div>
      <div class="alert-box" id="alert-box">
        Paciente possui um critério que exige atenção ou contraindicação absoluta ao método.
      </div>
    </div>
  </div>

  <!-- ── RESULTADO ── -->
  <div class="result-card" id="result-card">
    <div class="result-top">
      <div class="result-score-wrap">
        <div class="result-score-num" id="res-score">0</div>
        <div class="result-score-label">pontos ESPRI</div>
      </div>
      <div class="result-class-wrap">
        <div class="result-class-label">Classificação</div>
        <div class="result-class-name" id="res-class">Lista geral</div>
      </div>
    </div>
    <div class="result-text-area">
      <div class="result-text-label">Texto para o PEC</div>
      <div class="generated-text" id="gen-text"></div>
      <div class="char-counter" id="char-counter">Caracteres: 0/400</div>
    </div>
    <div class="btn-row">
      <button class="btn btn-copy" id="btn-copy" onclick="copyText()">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="white" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2H3.5A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="white" stroke-width="1.5"/></svg>
        Copiar texto para o PEC
      </button>
      <button class="btn btn-clear" onclick="clearAll()">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8L6 11L13 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Limpar
      </button>
    </div>
  </div>

</div><!-- /page-wrap -->

<script>
/* ── Short label map for text generation ─── */
const SHORT = {
  // 3 pts
  "Adolescente de 14 a 17 anos com vida sexual ativa ou risco de gestação": "adolescência",
  "Gestação prévia na adolescência ou puerpério adolescente": "gestação na adolescência",
  "Situação de rua": "situação de rua",
  "Uso abusivo / dependência de álcool ou outras drogas": "uso de drogas/álcool",
  "Profissional do sexo": "profissional do sexo",
  "Privação de liberdade ou egressa recente": "privação de liberdade",
  "Violência sexual, doméstica ou exploração sexual": "violência/exploração sexual",
  "Condição clínica em que gestação oferece alto risco": "risco clínico gestacional",
  "Uso de medicação potencialmente teratogênica": "medicação teratogênica",
  // 2 pts
  "Pós-parto ou pós-abortamento recente com gestação não planejada": "puerpério/pós-aborto",
  "Baixa adesão comprovada a pílula ou injetável": "baixa adesão",
  "Contraindicação ou intolerância a estrogênio": "CI a estrogênio",
  "Dificuldade de acesso regular à unidade": "dificuldade de acesso",
  "Transtorno mental grave com dificuldade de adesão contraceptiva": "transtorno mental",
  "Deficiência intelectual / cognitiva, com avaliação individualizada": "def. cognitiva",
  // 1 pt
  "Multiparidade com desejo de evitar nova gestação": "multiparidade",
  "Recusa ou contraindicação ao DIU": "recusa ao DIU",
  "Gestação não planejada prévia": "gest. não planejada",
  "Jovem de 18 a 24 anos com dificuldade de adesão contraceptiva": "jovem 18-24a",
  "Demanda espontânea por método de longa duração": "demanda espontânea",
};

function calcScore() {
  let total = 0;
  document.querySelectorAll('#list-3 input, #list-2 input, #list-1 input').forEach(cb => {
    if (cb.checked) {
      const item = cb.closest('.check-item');
      total += parseInt(item.dataset.pts, 10);
    }
  });
  return total;
}

function getClass(score) {
  if (score === 0) return { label: 'Lista geral', badgeClass: 'badge-geral', color: null };
  if (score <= 3)  return { label: 'Baixa prioridade', badgeClass: 'badge-baixa', color: '#2563EB' };
  if (score <= 6)  return { label: 'Prioridade intermediária', badgeClass: 'badge-media', color: 'var(--yellow)' };
  return           { label: 'Alta prioridade', badgeClass: 'badge-alta', color: 'var(--red)' };
}

function getCheckedLabels() {
  const labels = [];
  document.querySelectorAll('#list-3 input:checked, #list-2 input:checked, #list-1 input:checked').forEach(cb => {
    const txt = cb.closest('.check-item').querySelector('.check-text').textContent.trim();
    labels.push(SHORT[txt] || txt.slice(0, 30));
  });
  return labels;
}

function hasAlert() {
  return !!document.querySelector('#list-alert input:checked');
}

function buildText(score, cls) {
  const idade   = document.getElementById('f-idade').value.trim();
  const dum     = document.getElementById('f-dum').value.trim();
  const g       = document.getElementById('f-g').value.trim();
  const p       = document.getElementById('f-p').value.trim();
  const a       = document.getElementById('f-a').value.trim();
  const metodo  = document.getElementById('f-metodo').value.trim();
  const labels  = getCheckedLabels();
  const alert   = hasAlert();

  // Build pieces
  const parts = [];
  parts.push('Paciente avaliada para implante subdérmico.');

  // Demographics
  const demo = [];
  if (idade) demo.push(idade + ' anos');
  if (dum)   demo.push('DUM ' + dum);
  const hasObstetric = g !== '' || p !== '' || a !== '';
  if (hasObstetric) {
    const gv = g !== '' ? g : '?';
    const pv = p !== '' ? p : '?';
    const av = a !== '' ? a : '?';
    demo.push('G' + gv + 'P' + pv + 'A' + av);
  }
  if (metodo) demo.push('método: ' + metodo.toLowerCase());
  if (demo.length) parts.push(demo.join(', ') + '.');

  // Criteria
  if (labels.length) {
    parts.push('ESPRI: ' + labels.join(', ') + '.');
  } else {
    parts.push('Sem critérios ESPRI assinalados.');
  }

  // Score + classification
  parts.push('Pontuação: ' + score + ' pt' + (score !== 1 ? 's' : '') + '. ' + cls.label + '.');

  // Closing
  const closing = alert
    ? 'Encaminho para avaliação clínica prévia à inserção conforme protocolo municipal.'
    : 'Encaminho para inserção conforme protocolo municipal.';
  parts.push(closing);

  let full = parts.join(' ');

  // If over 400 chars, compress criteria
  if (full.length > 400) {
    const shortLabels = labels.length
      ? (labels.length <= 3 ? labels.join(', ') : labels.slice(0, 2).join(', ') + ' e outros')
      : 'nenhum';

    const compact = [
      'Paciente avaliada para implante subdérmico.',
    ];
    if (demo.length) compact.push(demo.join(', ') + '.');
    compact.push('ESPRI: ' + shortLabels + '.');
    compact.push('Pontuação: ' + score + '. ' + cls.label + '.');
    compact.push(closing);
    full = compact.join(' ');
  }

  // Hard truncate at 400, cut at last space before limit
  if (full.length > 400) {
    full = full.slice(0, 397).replace(/\s\S*$/, '') + '…';
  }

  return full;
}

function update() {
  const score = calcScore();
  const cls   = getClass(score);
  const text  = buildText(score, cls);
  const alert = hasAlert();

  // Sticky bar
  document.getElementById('score-bar-num').textContent = score;
  const badgeEl = document.getElementById('score-bar-badge');
  badgeEl.textContent = cls.label;
  badgeEl.className = 'badge ' + cls.badgeClass;

  // Result card
  document.getElementById('res-score').textContent = score;
  const clsEl = document.getElementById('res-class');
  clsEl.textContent = cls.label;
  clsEl.style.color = cls.color || 'var(--white)';

  // Text output
  document.getElementById('gen-text').textContent = text;
  const counter = document.getElementById('char-counter');
  counter.textContent = 'Caracteres: ' + text.length + '/400';
  counter.classList.toggle('over', text.length > 400);

  // Alert
  document.getElementById('alert-box').classList.toggle('visible', alert);

  // Visual feedback on check-items
  document.querySelectorAll('.check-list .check-item').forEach(item => {
    const cb = item.querySelector('input[type=checkbox]');
    if (item.dataset.alert) {
      item.classList.toggle('checked-alert', cb.checked);
    } else {
      item.classList.toggle('checked', cb.checked);
    }
  });
}

function copyText() {
  const text = document.getElementById('gen-text').textContent;
  const btn = document.getElementById('btn-copy');
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(() => {
      btn.textContent = '✓ Texto copiado!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="white" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2H3.5A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="white" stroke-width="1.5"/></svg> Copiar texto para o PEC';
        btn.classList.remove('copied');
      }, 2000);
    });
  } else {
    // Fallback
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.position = 'fixed';
    ta.style.opacity = '0';
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    btn.textContent = '✓ Copiado!';
    btn.classList.add('copied');
    setTimeout(() => {
      btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="white" stroke-width="1.5"/><path d="M11 5V3.5A1.5 1.5 0 009.5 2H3.5A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="white" stroke-width="1.5"/></svg> Copiar texto para o PEC';
      btn.classList.remove('copied');
    }, 2000);
  }
}

function clearAll() {
  document.querySelectorAll('input[type=checkbox]').forEach(cb => cb.checked = false);
  document.getElementById('f-idade').value = '';
  document.getElementById('f-dum').value = '';
  document.getElementById('f-g').value = '';
  document.getElementById('f-p').value = '';
  document.getElementById('f-a').value = '';
  document.getElementById('f-metodo').value = '';
  document.getElementById('f-resumo').value = '';
  update();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// Attach listeners
document.querySelectorAll('input[type=checkbox]').forEach(cb => cb.addEventListener('change', update));
['f-idade','f-dum','f-g','f-p','f-a','f-metodo','f-resumo'].forEach(id => {
  document.getElementById(id).addEventListener('input', update);
});

// Init
update();
</script>
</body>
</html>
